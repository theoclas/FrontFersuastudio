# Opción A — API en tu PC (Nest local, puerto típico 3000)
# VITE_API_URL=http://localhost:3000/api

# Opción B — API en Hostinger (producción / pruebas locales contra el back desplegado)
#   VITE_API_URL=https://backfersuastudio.fersuastudio.com/api
# Opción A — API en tu PC:
#   VITE_API_URL=http://localhost:3000/api
VITE_API_URL=http://localhost:3000/api
